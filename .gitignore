# === Compiled binaries & object files ===
*.o
*.out
a.out
gmon.out

# lab_1 — matrix multiply (mmN, mmN_4/_8, mmN_O2)
/lab_1/mm[0-9]
/lab_1/mm[0-9]_*

# lab_3 — Gaussian elimination (ge1..ge8)
/lab_3/ge[0-9]

# lab_4 — Cholesky factorization (chol1..chol6)
/lab_4/chol[0-9]

# zad_1 / zad_2 — per-version compiled binaries
/zad_1/*/base
/zad_2/*/ge
/zad_2/*/ge_papi

# === Generated data & run artifacts ===
# Large generated input (~52 MB each) — regenerate with zad_1/gen_file.py
/zad_1/*/file.txt
# gprof / metrics output regenerated by the Makefiles
/zad_1/*/gmon.out
/zad_1/*/raport.txt
/zad_1/*/metrics.txt
/zad_2/*/metrics.txt
/zad_2/papi.txt

# Submission archives
*.zip

# === LaTeX build artifacts ===
*.aux
*.log
*.toc
*.lof
*.lot
*.synctex.gz
*.fls
*.fdb_latexmk
*.bbl
*.blg

# === Python ===
__pycache__/
*.py[cod]
.venv/
venv/

# === Editor / OS ===
.claude/settings.local.json
.DS_Store

# === Never ignore source files (overrides binary patterns above) ===
!*.c
!*.cpp
!*.h
